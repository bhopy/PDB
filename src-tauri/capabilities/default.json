{
  "$schema": "https://schema.tauri.app/config/2/capability",
  "identifier": "default",
  "description": "Default permissions for the app",
  "windows": ["main"],
  "permissions": [
    "core:default",
    "shell:allow-open",
    "dialog:allow-open",
    "dialog:allow-save",
    "fs:allow-read",
    "fs:allow-write",
    "fs:allow-exists",
    "fs:allow-mkdir",
    "fs:allow-remove",
    "fs:allow-copy-file",
    {
      "identifier": "fs:scope",
      "allow": ["E:\\PDB\\**", "$APPDATA/**", "$HOME/**", "$DESKTOP/**", "$DOWNLOAD/**"]
    }
  ]
}
